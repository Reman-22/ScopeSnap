{
  "info": {
    "_postman_id": "scopesnap-full-api",
    "name": "ScopeSnap API",
    "description": "Complete ScopeSnap API collection.\n\n1. cd backend && php artisan serve\n2. Run Register (Freelancer) or Login\n3. Token auto-saves to {{token}}\n4. Run Create Project → IDs auto-save to variables\n\nDocs: backend/docs/README.md",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000/api" },
    { "key": "token", "value": "" },
    { "key": "project_id", "value": "1" },
    { "key": "section_id", "value": "1" },
    { "key": "item_id", "value": "1" },
    { "key": "client_id", "value": "1" },
    { "key": "change_request_id", "value": "1" },
    { "key": "share_link", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (Freelancer)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "if (pm.response.code === 201) {",
                "  const j = pm.response.json();",
                "  pm.collectionVariables.set('token', j.data.token);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ahmed Dev\",\n  \"email\": \"freelancer@example.com\",\n  \"password\": \"Password1\",\n  \"role\": \"freelancer\"\n}"
            },
            "url": "{{base_url}}/auth/register"
          }
        },
        {
          "name": "Register (Client)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "if (pm.response.code === 201) {",
                "  const j = pm.response.json();",
                "  pm.collectionVariables.set('token', j.data.token);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sara Client\",\n  \"email\": \"client@example.com\",\n  \"password\": \"Password1\",\n  \"role\": \"client\"\n}"
            },
            "url": "{{base_url}}/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "if (pm.response.code === 200) {",
                "  const j = pm.response.json();",
                "  pm.collectionVariables.set('token', j.data.token);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"freelancer@example.com\",\n  \"password\": \"Password1\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/auth/me"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ahmed Updated\",\n  \"phone\": \"0501234567\"\n}"
            },
            "url": "{{base_url}}/auth/profile"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Clients (Freelancer)",
      "item": [
        {
          "name": "List Clients",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/clients"
          }
        },
        {
          "name": "Create Client",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "if (pm.response.code === 201) {",
                "  pm.collectionVariables.set('client_id', pm.response.json().data.client.id);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sara Client\",\n  \"email\": \"sara.contact@example.com\",\n  \"phone\": \"0501234567\",\n  \"company\": \"Acme Co\"\n}"
            },
            "url": "{{base_url}}/clients"
          }
        },
        {
          "name": "Get Client",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/clients/{{client_id}}"
          }
        },
        {
          "name": "Update Client",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sara Updated\",\n  \"email\": \"sara.updated@example.com\",\n  \"phone\": \"0509999999\",\n  \"company\": \"New Co\"\n}"
            },
            "url": "{{base_url}}/clients/{{client_id}}"
          }
        },
        {
          "name": "Delete Client",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/clients/{{client_id}}"
          }
        }
      ]
    },
    {
      "name": "Projects (Freelancer)",
      "item": [
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/projects"
          }
        },
        {
          "name": "Create Project",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "if (pm.response.code === 201) {",
                "  const p = pm.response.json().data.project;",
                "  pm.collectionVariables.set('project_id', p.id);",
                "  pm.collectionVariables.set('share_link', p.shareLink || p.share_link);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"E-commerce Store\",\n  \"description\": \"Online clothing store\"\n}"
            },
            "url": "{{base_url}}/projects"
          }
        },
        {
          "name": "Get Project",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/projects/{{project_id}}"
          }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Store\",\n  \"description\": \"Updated description\"\n}"
            },
            "url": "{{base_url}}/projects/{{project_id}}"
          }
        },
        {
          "name": "Send to Client",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/projects/{{project_id}}/send"
          }
        },
        {
          "name": "Get Project Approval",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/projects/{{project_id}}/project-approval"
          }
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/projects/{{project_id}}"
          }
        }
      ]
    },
