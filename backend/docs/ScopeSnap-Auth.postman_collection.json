{
  "info": {
    "_postman_id": "scopesnap-auth-api",
    "name": "ScopeSnap Auth API",
    "description": "User auth endpoints for ScopeSnap Laravel backend.\n\n1. Run: cd backend && php artisan serve\n2. Run Register or Login first\n3. Token is auto-saved to {{token}} for protected routes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "Register",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "    const json = pm.response.json();",
              "    pm.collectionVariables.set('token', json.data.token);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Ahmed Dev\",\n  \"email\": \"ahmed@example.com\",\n  \"password\": \"Password1\",\n  \"role\": \"freelancer\"\n}"
        },
        "url": "{{base_url}}/auth/register"
      }
    },
    {
      "name": "Register (with image)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "    const json = pm.response.json();",
              "    pm.collectionVariables.set('token', json.data.token);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "name",
              "value": "Sara Client",
              "type": "text"
            },
            {
              "key": "email",
              "value": "sara@example.com",
              "type": "text"
            },
            {
              "key": "password",
              "value": "Password1",
              "type": "text"
            },
            {
              "key": "role",
              "value": "client",
              "type": "text"
            },
            {
              "key": "img",
              "type": "file",
              "src": [],
              "description": "Optional — pick a jpg/png/gif/webp file"
            }
          ]
        },
        "url": "{{base_url}}/auth/register"
      }
    },
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const json = pm.response.json();",
              "    pm.collectionVariables.set('token', json.data.token);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"ahmed@example.com\",\n  \"password\": \"Password1\"\n}"
        },
        "url": "{{base_url}}/auth/login"
      }
    },
    {
      "name": "Me",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/auth/me"
      }
    },
    {
      "name": "Update Profile",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Ahmed Updated\",\n  \"phone\": \"0501234567\"\n}"
        },
        "url": "{{base_url}}/auth/profile"
      }
    },
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/auth/logout"
      }
    }
  ]
}
